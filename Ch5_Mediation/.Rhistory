TE   = p11 - p00;',
seed = 90291,
burn = 10000,
iter = 10000)
# probit regression for the b-path
mod1 <- rblimp(
data = employee,
ordinal = 'turnover',             # ordinal => probit (latent response)
center  = 'lmx male',
model = '
apath:
jobsat ~ intercept@a0 lmx@a1 male;
jobsat@m_resvar;
bpath:
turnover ~ intercept@b0 jobsat@b1 lmx@b2 male;
predictors:
lmx ~ male;',
parameters = '
s = sqrt(lmx.totalvar);
# conditional (Geldhof) indirect effect at three LMX values
eta_lo  = b0 + b1*(a0 + a1*(-s)) + b2*(-s);
eta_mid = b0 + b1*(a0 + a1*( 0)) + b2*( 0);
eta_hi  = b0 + b1*(a0 + a1*( s)) + b2*( s);
cond_lo  = a1 * b1 * exp(-0.5*eta_lo^2)  / sqrt(2*_pi);
cond_mid = a1 * b1 * exp(-0.5*eta_mid^2) / sqrt(2*_pi);
cond_hi  = a1 * b1 * exp(-0.5*eta_hi^2)  / sqrt(2*_pi);
# causally-defined natural effects, x1 = +1 SD vs x0 = mean
denom = sqrt(b1^2 * m_resvar + 1);
p11 = phi( (b0 + b2*s + b1*(a0 + a1*s)) / denom );
p10 = phi( (b0 + b2*s + b1*(a0 + a1*0)) / denom );
p01 = phi( (b0 + b2*0 + b1*(a0 + a1*s)) / denom );
p00 = phi( (b0 + b2*0 + b1*(a0 + a1*0)) / denom );
TNIE = p11 - p10;
PNIE = p01 - p00;
PNDE = p10 - p00;
TNDE = p11 - p01;
TE   = p11 - p00;',
seed = 90291,
burn = 10000,
iter = 10000)
output(mod1)
data_url <- 'https://raw.githubusercontent.com/blimp-stats/blimp-book/main/data/pain.csv'
# create data frame from github data
pain <- read.csv(data_url)
summary(pain$depress)
View(pain)
pain$dephigh <- ifelse(
is.na(pain$depress),
NA,
ifelse(pain$depress > 18, 1, 0)
)
mod1 <- rblimp(
data = pain,
ordinal = 'male dephigh txgrp',             # ordinal => probit (latent response)
center  = 'male age',
model = '
apath:
interfere ~ intercept@a0 txgrp@a1 male age;
bpath:
dephigh ~ intercept@b0 interfere@b1 txgrp@b2 male age; DEBUG: compact_output',
parameters = '
ind_0 = a1 * b1 * exp( -0.5*( b0 + b1*(a0 + a1*0) + b2*0 )^2 ) / sqrt(2*_pi);
ind_1 = a1 * b1 * exp( -0.5*( b0 + b1*(a0 + a1*1) + b2*1 )^2 ) / sqrt(2*_pi);
ind_diff = ind_1 - ind_0;',
seed = 90291,
burn = 10000,
iter = 10000)
output(mod1)
