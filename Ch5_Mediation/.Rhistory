summary(employee$lmx)
employee$relqual <- ifelse(
is.na(employee$lmx),
NA,
ifelse(employee$relqual > 11, 1, 0)
)
mod1 <- rblimp(
data = employee,
ordinal = 'turnover relqual',             # ordinal => probit (latent response)
center  = 'male',
model = '
apath:
jobsat ~ intercept@a0 relqual@a1 male;
jobsat@m_resvar;
bpath:
turnover ~ intercept@b0 jobsat@b1 relqual@b2 male;',
parameters = '
# ---- 1. Traditional product: effect on the LATENT response y*, not on Y ----
ind_latent = a1 * b1;
# ---- 2. Conditional indirect effects (Geldhof), evaluated at x = 0 and x = 1 ----
eta0 = b0 + b1*a0;
eta1 = b0 + b1*(a0 + a1) + b2;
cond0     = a1 * b1 * exp(-0.5*eta0^2) / sqrt(2*_pi);
cond1     = a1 * b1 * exp(-0.5*eta1^2) / sqrt(2*_pi);
cond_diff = cond1 - cond0;
# ---- 3. Causally-defined natural effects (probit closed form) ----
denom = sqrt(b1^2 * m_resvar + 1);
p11 = phi( (b0 + b2 + b1*(a0 + a1)) / denom );
p10 = phi( (b0 + b2 + b1*(a0     )) / denom );
p01 = phi( (b0      + b1*(a0 + a1)) / denom );
p00 = phi( (b0      + b1*(a0     )) / denom );
TNIE = p11 - p10;
PNIE = p01 - p00;
PNDE = p10 - p00;
TNDE = p11 - p01;
TE   = p11 - p00;
pm   = TNIE / TE;
# ---- 4. Odds-ratio scale (VanderWeele & Vansteelandt; Muthen 8.1.5) ----
TNIE_OR = (p11/(1-p11)) / (p10/(1-p10));
PNDE_OR = (p10/(1-p10)) / (p00/(1-p00));
TE_OR   = (p11/(1-p11)) / (p00/(1-p00));',
seed = 90291,
burn = 10000,
iter = 10000)
employee$relqual <- ifelse(
is.na(employee$lmx),
NA,
ifelse(employee$lmx > 11, 1, 0)
)
summary(employee$relqual)
mod1 <- rblimp(
data = employee,
ordinal = 'turnover relqual',             # ordinal => probit (latent response)
center  = 'male',
model = '
apath:
jobsat ~ intercept@a0 relqual@a1 male;
jobsat@m_resvar;
bpath:
turnover ~ intercept@b0 jobsat@b1 relqual@b2 male;',
parameters = '
# ---- 1. Traditional product: effect on the LATENT response y*, not on Y ----
ind_latent = a1 * b1;
# ---- 2. Conditional indirect effects (Geldhof), evaluated at x = 0 and x = 1 ----
eta0 = b0 + b1*a0;
eta1 = b0 + b1*(a0 + a1) + b2;
cond0     = a1 * b1 * exp(-0.5*eta0^2) / sqrt(2*_pi);
cond1     = a1 * b1 * exp(-0.5*eta1^2) / sqrt(2*_pi);
cond_diff = cond1 - cond0;
# ---- 3. Causally-defined natural effects (probit closed form) ----
denom = sqrt(b1^2 * m_resvar + 1);
p11 = phi( (b0 + b2 + b1*(a0 + a1)) / denom );
p10 = phi( (b0 + b2 + b1*(a0     )) / denom );
p01 = phi( (b0      + b1*(a0 + a1)) / denom );
p00 = phi( (b0      + b1*(a0     )) / denom );
TNIE = p11 - p10;
PNIE = p01 - p00;
PNDE = p10 - p00;
TNDE = p11 - p01;
TE   = p11 - p00;
pm   = TNIE / TE;
# ---- 4. Odds-ratio scale (VanderWeele & Vansteelandt; Muthen 8.1.5) ----
TNIE_OR = (p11/(1-p11)) / (p10/(1-p10));
PNDE_OR = (p10/(1-p10)) / (p00/(1-p00));
TE_OR   = (p11/(1-p11)) / (p00/(1-p00));',
seed = 90291,
burn = 10000,
iter = 10000)
output(mod1)
