#------------------------------------------------------------------------------#
# LOAD R PACKAGES ----
#------------------------------------------------------------------------------#
library(ggplot2)
library(rblimp)
set_blimp('/applications/blimp/blimp-nightly')
#------------------------------------------------------------------------------#
# READ DATA ----
#------------------------------------------------------------------------------#
# github url for raw data
data_url <- 'https://raw.githubusercontent.com/blimp-stats/blimp-book/main/data/trial_stacked.csv'
# create data frame from github data
trial <- read.csv(data_url)
ggplot(trial, aes(x = visit, y = severity)) +
stat_summary(fun = mean, geom = "line",  na.rm = TRUE) +
stat_summary(fun = mean, geom = "point", na.rm = TRUE)
mod1 <- rblimp(
data = trial,
clusterid = 'person',
model = 'severity ~ intercept visit | visit;',
seed = 90291,
burn = 10000,
iter = 10000)
# print output
output(mod1)
# =====================================================================
# Simulated 3-variable data set for a 2SLS / instrumental-variable model
# For Janet's cortisol -> calories analysis (demo for Blimp setup)
#
#   Z = condition  : instrument (randomized stress manipulation, 0/1)
#   X = cortisol   : endogenous predictor (stress-induced cortisol)
#   Y = calories   : outcome
#
# Structural (data-generating) model:
#   cortisol  = a0 + a1*condition + u        # stage-1 / instrument relevance
#   calories  = b0 + b1*cortisol  + e        # stage-2 / structural effect
#   cor(u, e) = rho  != 0                     # <- this is the endogeneity
#
# The nonzero residual correlation (rho) is the confounding that makes a
# naive OLS regression of calories on cortisol BIASED. The instrument
# (condition) is what lets us recover the true causal effect b1.
# =====================================================================
set.seed(20260724)
library(MASS)
N   <- 500      # sample size
a0  <- 0.00     # cortisol intercept
a1  <- 1.50     # effect of condition on cortisol (first-stage strength)
b0  <- 0.00     # calories intercept
b1  <- 0.40     # <<< TRUE CAUSAL EFFECT of cortisol on calories >>>
rho <- 0.50     # residual correlation = endogeneity (confounding)
## --- correlated disturbances create the endogeneity ------------------
Sigma <- matrix(c(1, rho,
rho, 1), nrow = 2)
E <- MASS::mvrnorm(N, mu = c(0, 0), Sigma = Sigma)
u <- E[, 1]     # cortisol disturbance
e <- E[, 2]     # calories disturbance
## --- randomized instrument + structural equations --------------------
condition <- rbinom(N, size = 1, prob = 0.5)      # Z: stress vs. control
cortisol  <- a0 + a1 * condition + u              # X (endogenous)
calories  <- b0 + b1 * cortisol   + e             # Y (outcome)
dat <- data.frame(condition = condition,
cortisol  = round(cortisol, 3),
calories  = round(calories, 3))
## --- what the data show ---------------------------------------------
cat("\n================ TRUE VALUES ================\n")
cat(sprintf("First-stage effect  a1 = %.2f\n", a1))
cat(sprintf("TRUE causal effect  b1 = %.2f\n", b1))
cat(sprintf("Residual cor (endog) rho = %.2f\n", rho))
## 1) First stage: does the instrument move cortisol? (relevance check)
fs <- lm(cortisol ~ condition, data = dat)
Fstat <- summary(fs)$fstatistic[1]
cat("\n---- First stage: cortisol ~ condition ----\n")
cat(sprintf("  a1_hat = %.3f   (F = %.1f; want >> 10 for a strong instrument)\n",
coef(fs)["condition"], Fstat))
## 2) NAIVE OLS (ignores endogeneity -> biased, should overshoot 0.40)
ols <- lm(calories ~ cortisol, data = dat)
cat("\n---- Naive OLS: calories ~ cortisol (BIASED) ----\n")
cat(sprintf("  b1_hat = %.3f\n", coef(ols)["cortisol"]))
## 3) 2SLS by hand: regress Y on the stage-1 PREDICTED cortisol
xhat <- fitted(fs)
tsls <- lm(dat$calories ~ xhat)
cat("\n---- 2SLS: calories ~ predicted-cortisol (RECOVERS b1) ----\n")
cat(sprintf("  b1_hat = %.3f\n", coef(tsls)[2]))
## 3b) Just-identified check: Wald / ratio estimator = cov(Z,Y)/cov(Z,X)
wald <- cov(dat$condition, dat$calories) / cov(dat$condition, dat$cortisol)
cat(sprintf("  (Wald ratio estimator = %.3f -- identical, single instrument)\n", wald))
## 4) Control-function / 2SRI: add the stage-1 residual as a covariate
##    coef on ORIGINAL cortisol equals the 2SLS estimate
vres <- resid(fs)
cf <- lm(calories ~ cortisol + vres, data = dat)
cat("\n---- Control function: calories ~ cortisol + stage1-residual ----\n")
cat(sprintf("  b1_hat = %.3f   (residual coef p = %.3f -> tests endogeneity)\n",
coef(cf)["cortisol"], summary(cf)$coef["vres", 4]))
## --- write the data set ---------------------------------------------
write.csv(dat, "cortisol_iv_demo.csv", row.names = FALSE)
cat("\nSaved cortisol_iv_demo.csv  (", nrow(dat), "rows x 3 variables )\n")
