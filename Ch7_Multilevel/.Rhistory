#------------------------------------------------------------------------------#
# LOAD R PACKAGES ----
#------------------------------------------------------------------------------#
library(ggplot2)
library(rblimp)
set_blimp('/applications/blimp/blimp-nightly')
#------------------------------------------------------------------------------#
# READ DATA ----
#------------------------------------------------------------------------------#
# github url for raw data
data_url <- 'https://raw.githubusercontent.com/blimp-stats/blimp-book/main/data/mathprobsolve.csv'
# create data frame from github data
mathprobsolve <- read.csv(data_url)
mod <- rblimp(
data = mathprobsolve,
clusterid = 'school',
nominal = 'condition frlunch',
# fixed = 'probsolve1 condition',
center = 'groupmean = stanmath hispanic',
model = 'psolvepst ~ intercept@mu0 stanmath hispanic stanmath.mean hispanic.mean condition',
seed = 90291,
burn = 10000,
iter = 10000)
# print output
output(mod)
mod <- rblimp(
data = mathprobsolve,
clusterid = 'school',
ordinal = 'condition frlunch hispanic',
# fixed = 'probsolve1 condition',
center = 'groupmean = stanmath hispanic',
model = 'psolvepst ~ intercept@mu0 stanmath frlunch stanmath.mean frlunch.mean condition',
seed = 90291,
burn = 10000,
iter = 10000)
# print output
output(mod)
mod <- rblimp(
data = mathprobsolve,
clusterid = 'school',
ordinal = 'condition frlunch hispanic',
# fixed = 'probsolve1 condition',
center = 'groupmean = stanmath hispanic',
model = 'psolvepst ~ intercept@mu0 stanmath hispanic stanmath.mean hispanic.mean condition',
seed = 90291,
burn = 10000,
iter = 10000)
# print output
output(mod)
mod <- rblimp(
data = mathprobsolve,
clusterid = 'school',
ordinal = 'condition frlunch hispanic male',
# fixed = 'probsolve1 condition',
center = 'groupmean = stanmath hispanic',
model = 'psolvepst ~ intercept@mu0 stanmath male stanmath.mean male.mean condition',
seed = 90291,
burn = 10000,
iter = 10000)
# print output
output(mod)
# mixed model specification
mod <- rblimp(
data = mathprobsolve,
clusterid = 'school',
ordinal = 'condition frlunch hispanic male',
# fixed = 'probsolve1 condition',
center = 'groupmean = stanmath hispanic',
model = 'psolvepst ~ intercept stanmath hispanic stanmath.mean hispanic.mean condition',
seed = 90291,
burn = 10000,
iter = 10000)
# print output
output(mod)
mod <- rblimp(
data = mathprobsolve,
clusterid = 'school',
ordinal = 'condition frlunch hispanic male',
# fixed = 'probsolve1 condition',
center = 'groupmean = stanmath hispanic',
model = 'psolvepst ~ intercept psolvepre hispanic psolvepre.mean hispanic.mean condition',
seed = 90291,
burn = 10000,
iter = 10000)
# print output
output(mod)
model1 <- rblimp(
data = mathprobsolve,
clusterid = 'school',
ordinal = 'hispanic',
model = 'intercept -> probsolve stanmath hispanic',
seed = 90291,
burn = 10000,
iter = 10000)
